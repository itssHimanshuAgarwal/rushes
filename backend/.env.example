# Copy this file to backend/.env and fill in real values.
# DO NOT commit backend/.env — it's gitignored.

# Required for /api/analyze (vision + continuity), /api/critique (Critic Agent)
OPENAI_API_KEY=

# Required for /api/generate-audio (SFX + ambient), /api/generate-music
ELEVENLABS_API_KEY=

# Required for /api/generate-shot (text-to-image Quick mode + text-to-video Full mode)
RUNWARE_API_KEY=

# Unused — kept for forward compatibility
ANTHROPIC_API_KEY=
