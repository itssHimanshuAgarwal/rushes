# Copy this file to backend/.env and fill in real values.
# DO NOT commit backend/.env — it's gitignored.

# Required for /api/analyze (vision + continuity), /api/critique (Critic Agent)
OPENAI_API_KEY=

# Required for /api/generate-audio (SFX + ambient), /api/generate-music
ELEVENLABS_API_KEY=

# Required for /api/generate-shot (text-to-image Quick mode + text-to-video Full mode)
RUNWARE_API_KEY=

# Unused — kept for forward compatibility
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini) — alternative LLM provider for vision +
# continuity + critic. Free tier is ~1500 RPD on gemini-2.0-flash.
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# "openai" (default) or "gemini" — selects which provider all LLM calls
# use. Switch to "gemini" if your OpenAI quota is exhausted.
LLM_PROVIDER=openai
